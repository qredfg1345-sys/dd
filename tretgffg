<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import {
    getFirestore,
    doc,
    setDoc,
    onSnapshot
  } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    projectId: "YOUR_PROJECT_ID",
    storageBucket: "YOUR_PROJECT.appspot.com",
    messagingSenderId: "YOUR_MESSAGING_SENDER_ID",
    appId: "YOUR_APP_ID"
  };

  const app = initializeApp(firebaseConfig);
  const firestore = getFirestore(app);
  const systemDocRef = doc(firestore, "trainSystem", "mainData");

  let db = {
    trains: [],
    routes: [],
    schedules: [],
    passengers: [],
    tickets: []
  };

  onSnapshot(systemDocRef, (snapshot) => {
    if (snapshot.exists()) {
      const data = snapshot.data();
      db = {
        trains: data.trains || [],
        routes: data.routes || [],
        schedules: data.schedules || [],
        passengers: data.passengers || [],
        tickets: data.tickets || []
      };
    } else {
      db = {
        trains: [],
        routes: [],
        schedules: [],
        passengers: [],
        tickets: []
      };
    }

    updateUI();
  }, (error) => {
    console.error("Realtime listener error:", error);
    alert("Failed to load realtime data from Firebase.");
  });

  async function save() {
    try {
      await setDoc(systemDocRef, db);
      updateUI();
    } catch (error) {
      console.error("Save error:", error);
      alert("Failed to save data to Firebase.");
    }
  }

  window.handleLogin = function () {
    const u = document.getElementById('user').value;
    const p = document.getElementById('pass').value;
    const role = document.getElementById('role-select').value;

    if ((u === 'admin' && p === 'admin') || (u === 'staff' && p === 'staff')) {
      document.getElementById('login-overlay').style.display = 'none';
      document.getElementById('sidebar').style.display = 'flex';
      document.getElementById('main').style.display = 'block';
      document.getElementById('portal-name').innerText = role === 'admin' ? 'Admin Portal' : 'Staff Portal';
      document.getElementById('admin-menu').style.display = role === 'admin' ? 'block' : 'none';
      document.getElementById('staff-menu').style.display = role === 'staff' ? 'block' : 'none';
      show(role === 'admin' ? 'sec-trains' : 'sec-passengers');
      updateUI();
    } else {
      alert("Invalid Login");
    }
  };

  window.show = function (id) {
    document.querySelectorAll('.container').forEach(c => c.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  };

  window.addUpdateTrain = async function () {
    const id = document.getElementById('train_id').value.trim();
    const ty = document.getElementById('train_type').value.trim();

    if (!id || !ty) return alert("Fill all fields");

    const idx = db.trains.findIndex(t => t.id === id);

    if (idx > -1) {
      db.trains[idx].type = ty;
    } else {
      db.trains.push({ id, type: ty });
    }

    document.getElementById('train_id').value = '';
    document.getElementById('train_type').value = '';
    await save();
  };

  window.editTrain = function (id, type) {
    document.getElementById('train_id').value = id;
    document.getElementById('train_type').value = type;
  };

  window.addUpdateRoute = async function () {
    const p = document.getElementById('route_path').value.trim();
    const idx = document.getElementById('edit_route_idx').value;

    if (!p) return;

    if (idx == -1) {
      db.routes.push(p);
    } else {
      db.routes[idx] = p;
    }

    document.getElementById('edit_route_idx').value = -1;
    document.getElementById('route_path').value = '';
    await save();
  };

  window.editRoute = function (i) {
    document.getElementById('route_path').value = db.routes[i];
    document.getElementById('edit_route_idx').value = i;
  };

  window.addUpdateSchedule = async function () {
    const sid = document.getElementById('edit_sch_id').value;

    const s = {
      id: sid == -1 ? Date.now() : parseInt(sid),
      train: document.getElementById('sch_train').value,
      route: document.getElementById('sch_route').value,
      time: document.getElementById('sch_time').value,
      seats: parseInt(document.getElementById('sch_seats').value)
    };

    if (!s.train || !s.route || !s.time || isNaN(s.seats)) {
      return alert("Fill all schedule fields");
    }

    if (sid == -1) {
      db.schedules.push(s);
    } else {
      const index = db.schedules.findIndex(x => x.id == sid);
      if (index > -1) db.schedules[index] = s;
    }

    document.getElementById('edit_sch_id').value = -1;
    document.getElementById('sch_time').value = '';
    document.getElementById('sch_seats').value = '';
    await save();
  };

  window.editSch = function (id) {
    const s = db.schedules.find(x => x.id == id);
    if (!s) return;

    document.getElementById('sch_train').value = s.train;
    document.getElementById('sch_route').value = s.route;
    document.getElementById('sch_time').value = s.time;
    document.getElementById('sch_seats').value = s.seats;
    document.getElementById('edit_sch_id').value = s.id;
  };

  window.savePassenger = async function () {
    const name = document.getElementById('ps_name').value.trim();
    const id = document.getElementById('ps_id').value.trim();

    if (!name || !id) return alert("Fill all fields");
    if (id.length < 5) return alert("ID must be 5+ digits");
    if (db.passengers.some(p => p.id === id)) return alert("ID already exists!");

    db.passengers.push({ name, id });

    document.getElementById('ps_name').value = '';
    document.getElementById('ps_id').value = '';
    await save();
  };

  window.checkAvail = function () {
    const s = db.schedules.find(x => x.id == document.getElementById('tk_trip').value);

    if (s) {
      document.getElementById('avail_info').innerText = `Seats: ${s.seats}`;
      document.getElementById('avail_info').style.color = s.seats > 0 ? "green" : "red";
      document.getElementById('issue-ticket-area').style.display = s.seats > 0 ? 'block' : 'none';
    }
  };

  window.issueTicket = async function () {
    const s = db.schedules.find(x => x.id == document.getElementById('tk_trip').value);
    const passenger = document.getElementById('tk_passenger').value;

    if (s && s.seats > 0) {
      s.seats--;
      db.tickets.push({
        p: passenger,
        trip: s.route,
        sid: s.id,
        id: Date.now()
      });

      document.getElementById('issue-ticket-area').style.display = 'none';
      await save();
    } else {
      alert("No seats available");
    }
  };

  window.searchPS = function () {
    const q = document.getElementById('ps_search').value.toLowerCase();
    const res = db.passengers.filter(
      p => p.name.toLowerCase().includes(q) || p.id.includes(q)
    );

    renderTable('psList', res.map(r => `<tr><td>${r.name}</td><td>${r.id}</td></tr>`), 2);
  };

  window.processDetailedReport = function (type) {
    const display = document.getElementById('report-display-area');

    if (type === 'Fleet') {
      display.innerHTML = `
        <h4>Fleet Assets</h4>
        <table>
          <thead><tr><th>ID</th><th>Type</th></tr></thead>
          <tbody>${db.trains.map(t => `<tr><td>${t.id}</td><td>${t.type}</td></tr>`).join('')}</tbody>
        </table>
      `;
    } else {
      display.innerHTML = `
        <h4>Active Schedules</h4>
        <table>
          <thead><tr><th>Route</th><th>Seats</th></tr></thead>
          <tbody>${db.schedules.map(s => `<tr><td>${s.route}</td><td>${s.seats}</td></tr>`).join('')}</tbody>
        </table>
      `;
    }
  };

  window.delTrain = async function (id) {
    db.trains = db.trains.filter(t => t.id !== id);
    await save();
  };

  window.delRoute = async function (i) {
    db.routes.splice(i, 1);
    await save();
  };

  window.delSch = async function (id) {
    db.schedules = db.schedules.filter(s => s.id !== id);
    await save();
  };

  window.cancelTicket = async function (id, sid) {
    db.tickets = db.tickets.filter(t => t.id !== id);
    const s = db.schedules.find(x => x.id == sid);
    if (s) s.seats++;
    await save();
  };

  function renderTable(id, html, colspan = 4) {
    const tbody = document.querySelector(`#${id} tbody`);
    if (!tbody) return;
    tbody.innerHTML = html.join('') || `<tr><td colspan="${colspan}">No Data Available</td></tr>`;
  }

  function updateUI() {
    renderTable(
      'trainList',
      db.trains.map(t => `
        <tr>
          <td>${t.id}</td>
          <td>${t.type}</td>
          <td>
            <button class="action-btn upd-btn" onclick="editTrain('${t.id}','${t.type}')">Update</button>
            <button class="action-btn del-btn" onclick="delTrain('${t.id}')">Delete</button>
          </td>
        </tr>
      `),
      3
    );

    renderTable(
      'routeList',
      db.routes.map((r, i) => `
        <tr>
          <td>${r}</td>
          <td>
            <button class="action-btn upd-btn" onclick="editRoute(${i})">Update</button>
            <button class="action-btn del-btn" onclick="delRoute(${i})">Delete</button>
          </td>
        </tr>
      `),
      2
    );

    renderTable(
      'schList',
      db.schedules.map(s => `
        <tr>
          <td>${s.train}</td>
          <td>${s.route}</td>
          <td>${s.time}</td>
          <td>${s.seats}</td>
          <td>
            <button class="action-btn upd-btn" onclick="editSch(${s.id})">Update</button>
            <button class="action-btn del-btn" onclick="delSch(${s.id})">Delete</button>
          </td>
        </tr>
      `),
      5
    );

    renderTable(
      'psList',
      db.passengers.map(p => `<tr><td>${p.name}</td><td>${p.id}</td></tr>`),
      2
    );

    renderTable(
      'tkTable',
      db.tickets.map(t => `
        <tr>
          <td>${t.p}</td>
          <td>${t.trip}</td>
          <td><button class="action-btn del-btn" onclick="cancelTicket(${t.id}, ${t.sid})">Cancel</button></td>
        </tr>
      `),
      3
    );

    renderTable(
      'dailyView',
      db.schedules.map(s => `
        <tr>
          <td>${s.route}</td>
          <td>${s.time}</td>
          <td>${s.seats}</td>
        </tr>
      `),
      3
    );

    const schTrain = document.getElementById('sch_train');
    const schRoute = document.getElementById('sch_route');
    const tkPassenger = document.getElementById('tk_passenger');
    const tkTrip = document.getElementById('tk_trip');

    if (schTrain) {
      schTrain.innerHTML = db.trains.map(t => `<option>${t.id}</option>`).join('');
    }

    if (schRoute) {
      schRoute.innerHTML = db.routes.map(r => `<option>${r}</option>`).join('');
    }

    if (tkPassenger) {
      tkPassenger.innerHTML = db.passengers.map(
        p => `<option value="${p.name} (ID: ${p.id})">${p.name} (ID: ${p.id})</option>`
      ).join('');
    }

    if (tkTrip) {
      tkTrip.innerHTML = db.schedules.map(
        s => `<option value="${s.id}">${s.route} (${s.time})</option>`
      ).join('');
    }
  }
</script>
